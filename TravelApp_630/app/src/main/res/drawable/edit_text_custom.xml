<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="4dp">
        <shape>
            <corners android:radius="20dp" />
            <solid android:color="#1A000000" /> </shape>
    </item>

    <item android:bottom="4dp" android:right="2dp" android:left="2dp" android:top="2dp">
        <shape>
            <corners android:radius="20dp" />
            <solid android:color="#FFFFFF" />
            <stroke android:width="1dp" android:color="#DDDDDD" />
        </shape>
    </item>

    <item android:top="3dp" android:left="3dp" android:right="3dp" android:bottom="30dp">
        <shape>
            <corners android:radius="20dp" />
            <gradient
                android:angle="270"
                android:startColor="#15000000"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

</layer-list>