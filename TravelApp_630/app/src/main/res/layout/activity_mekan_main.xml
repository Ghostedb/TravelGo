<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/left_arrow"
                android:contentDescription="Geri"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/toolbarTitleBolge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BERLİN SARAYI"
                android:textColor="#000000"
                android:fontFamily="@font/geometos"
                android:textStyle="bold"
                android:textSize="23sp"
                android:letterSpacing="0.09"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="335dp"
            android:layout_height="252dp"
            android:layout_gravity="center"
            android:layout_marginTop="88dp"
            app:cardCornerRadius="32dp"
            >

            <ImageView
                android:id="@+id/imageViewMekanFoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:srcCompat="@drawable/berlin" />

            <androidx.cardview.widget.CardView
                android:layout_width="65dp"
                android:layout_height="26dp"
                android:layout_marginTop="16dp"
                android:layout_marginLeft="259dp"
                app:cardCornerRadius="30dp"
                app:cardBackgroundColor="#B3FFFFFF">

                <ImageView
                    android:id="@+id/imageView16"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    app:srcCompat="@drawable/sun"
                    android:layout_marginLeft="8dp"
                    android:layout_marginTop="6dp"
                    android:layout_gravity="start"/>

                <TextView
                    android:id="@+id/textView32"
                    android:layout_width="30dp"
                    android:layout_height="21dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:text="22ºC" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="300dp"
                android:layout_height="73dp"
                android:layout_gravity="center"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#B4FFFFFF"
                android:layout_marginTop="68dp">

                <TextView
                    android:id="@+id/textView37"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popülerlik Derecelendirme"
                    android:textColor="@color/white"
                    android:fontFamily="@font/arial"
                    android:layout_marginTop="18dp"
                    android:layout_marginLeft="8dp"/>

                <LinearLayout
                    android:layout_width="140dp"
                    android:layout_height="30dp"
                    android:layout_marginLeft="8dp"
                    android:layout_marginTop="38dp"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <ImageView
                        android:id="@+id/imageView17"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:padding="2dp"
                        app:srcCompat="@drawable/star2" />

                    <ImageView
                        android:id="@+id/imageView18"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:padding="2dp"
                        app:srcCompat="@drawable/star2" />

                    <ImageView
                        android:id="@+id/imageView19"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:padding="2dp"
                        app:srcCompat="@drawable/star2" />

                    <ImageView
                        android:id="@+id/imageView20"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:padding="2dp"
                        app:srcCompat="@drawable/star2" />

                    <ImageView
                        android:id="@+id/imageView21"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:padding="2dp"
                        app:srcCompat="@drawable/star2" />

                    <TextView
                        android:id="@+id/textView42"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="4.8"
                        android:textColor="@color/white"
                        android:layout_marginLeft="8dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/textView43"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2K İnceleme"
                    android:layout_gravity="end"
                    android:layout_marginTop="38dp"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginRight="18dp"/>


            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="310dp"
            android:layout_height="289dp"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="30dp">

            <TextView
                android:id="@+id/textView44"
                android:layout_width="102dp"
                android:layout_height="26dp"
                android:text="Öğrenci Bileti"
                android:gravity="center"
                android:fontFamily="@font/ariala"
                android:textSize="10sp"
                android:textColor="@color/white"
                android:layout_marginTop="24dp"
                android:layout_marginLeft="22dp"
                android:background="@drawable/text_ogrenci"/>

            <TextView
                android:id="@+id/textViewTutar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€80,00"
                android:textColor="@color/black"
                android:textSize="25sp"
                android:layout_gravity="end"
                android:layout_marginRight="33dp"
                android:layout_marginTop="21dp"/>

            <LinearLayout
                android:layout_width="180dp"
                android:layout_height="63dp"
                android:layout_gravity="center"
                android:layout_marginBottom="38dp"
                android:layout_marginRight="33dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView47"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Genel Giriş"
                    android:fontFamily="@font/helvatica"
                    android:textColor="@color/black"
                    android:textSize="28sp"/>

                <TextView
                    android:id="@+id/textView48"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tam Zamanlı Erişim"
                    android:textSize="16sp"
                    android:fontFamily="@font/arial"
                    android:textColor="#135BEC"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:orientation="horizontal">


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="70dp"
                        android:layout_height="20dp"
                        android:layout_marginLeft="18dp"
                        android:layout_marginTop="28dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imageView22"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:srcCompat="@drawable/add" />

                        <TextView
                            android:id="@+id/textView49"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Date"
                            android:textAlignment="center" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textViewTarih"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="12 Nis, 2026"
                        android:textColor="@color/black"
                        android:textAlignment="center"
                        android:layout_marginTop="16dp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="70dp"
                        android:layout_height="20dp"
                        android:layout_marginLeft="98dp"
                        android:layout_marginTop="28dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imageView23"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_weight="1"
                            app:srcCompat="@drawable/clock" />

                        <TextView
                            android:id="@+id/textView50"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Time"
                            android:textAlignment="center" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/textViewZaman"
                        android:layout_width="78dp"
                        android:layout_height="wrap_content"
                        android:text="14:30-16:30"
                        android:textColor="@color/black"
                        android:textAlignment="textEnd"
                        android:layout_marginLeft="98dp"
                        android:layout_marginTop="16dp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="175dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/textView54"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Price"
            android:textSize="17sp"
            android:layout_marginLeft="18dp"
            android:fontFamily="@font/helvatica"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewTutar2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€80,00"
                android:fontFamily="@font/geometos"
                android:textColor="@color/black"
                android:textSize="32sp"
                android:layout_marginLeft="18dp"/>

            <ImageView
                android:id="@+id/imageView24"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:layout_marginLeft="178dp"
                android:layout_marginBottom="18dp"
                app:srcCompat="@drawable/kullaniciler" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSatinAl"
            android:layout_width="329dp"
            android:layout_height="62dp"
            android:text="Hemen Satın Al"
            android:layout_gravity="center"
            app:cornerRadius="30dp"
            android:textStyle="bold"
            android:fontFamily="@font/bahnschrift"
            android:backgroundTint="#135BEC"

            app:icon="@drawable/shopping"
            app:iconGravity="textStart"
            app:iconSize="23dp"
            app:iconTint="#FFFFFF"

            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

