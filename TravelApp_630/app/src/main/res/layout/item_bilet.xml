<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="337dp"
    android:layout_marginVertical="12dp"
    app:cardCornerRadius="30dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="235dp"
        app:cardCornerRadius="30dp">

        <ImageView
            android:id="@+id/imgBiletFoto"
            android:layout_width="match_parent"
            android:layout_height="425dp"
            android:layout_marginTop="-88dp"
            android:scaleType="centerCrop"
            android:src="@drawable/berlin" />

        <TextView
            android:id="@+id/txtBiletMekanAdi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="151dp"
            android:fontFamily="@font/helvatica"
            android:text="Mekan Adı"
            android:textColor="@color/white"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/txtBiletUlke"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="49dp"
            android:layout_marginTop="198dp"
            android:fontFamily="@font/arial"
            android:text="Şehir/Ülke"
            android:textColor="#C2C5C6"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="21dp"
            android:layout_height="21dp"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="198dp"
            app:srcCompat="@drawable/pin" />
    </androidx.cardview.widget.CardView>

    <ImageView
        android:id="@+id/imageView32"
        android:layout_width="23dp"
        android:layout_height="23dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="48dp"
        android:layout_marginStart="32dp"
        android:src="@drawable/star2" />

    <TextView
        android:id="@+id/txtBiletPuan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4.8"
        android:layout_gravity="bottom"
        android:layout_marginStart="72dp"
        android:textColor="@color/black"
        android:layout_marginBottom="50dp"/>

    <TextView
        android:id="@+id/txtBiletInceleme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(1.12K)"
        android:fontFamily="@font/rubik"
        android:layout_gravity="bottom"
        android:layout_marginStart="102dp"
        android:textColor="@color/black"
        android:layout_marginBottom="49dp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ödenen Fiyat"
        android:fontFamily="@font/bahnschrift"
        android:layout_gravity="bottom"
        android:layout_marginStart="242dp"
        android:textStyle="bold"
        android:textSize="19sp"
        android:textColor="@color/black"
        android:layout_marginBottom="49dp" />

    <TextView
        android:id="@+id/txtBiletFiyat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="80.00€"
        android:fontFamily="@font/geometos"
        android:layout_gravity="bottom"
        android:layout_marginStart="252dp"
        android:textStyle="bold"
        android:textSize="25sp"
        android:textColor="#136DEC"
        android:layout_marginBottom="9dp" />
</androidx.cardview.widget.CardView>